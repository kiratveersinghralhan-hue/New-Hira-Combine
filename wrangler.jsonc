{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "newhira",
  "main": "./cloudflare/worker.js",
  "compatibility_date": "2026-07-18",
  "keep_vars": true,
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": true,
    "html_handling": "auto-trailing-slash"
  },
  "d1_databases": [
    {
      "binding": "DB"
    }
  ],
  "r2_buckets": [
    {
      "binding": "MEDIA"
    }
  ]
}
